@article{10.1371/journal.pone.0269454,
    doi = {10.1371/journal.pone.0269454},
    author = {Figà-Talamanca, Gianna AND Tanzi, Paola Musile AND D’Urzo, Eleonora},
    journal = {PLOS ONE},
    publisher = {Public Library of Science},
    title = {Robo-advisor acceptance: Do gender and generation matter?},
    year = {2022},
    month = {06},
    volume = {17},
    url = {https://doi.org/10.1371/journal.pone.0269454},
    pages = {1-13},
    abstract = {Robo-advice technology refers to services offered by a virtual financial advisor based on artificial intelligence. Research on the application of robo-advice technology already highlights the potential benefit in terms of financial inclusion. We analyze the process for adopting robo-advice through the technology acceptance model (TAM), focusing on a highly educated sample and exploring generational and gender differences. We find no significant gender difference in the causality links with adoption, although some structural differences still arise between male and female groups. Further, we find evidence that generational cohorts affect the path to future adoption of robo-advice technology. Indeed, the ease of use is the factor which triggers the adoption by Generation Z and Generation Y, whereas the perceived usefulness of robo-advice technology is the key factor driving Generation X+, who need to understand the ultimate purpose of a robo-advice technology tool before adopting it. Overall, the above findings may reflect that, while gender differences are wiped out in a highly educated population, generation effects still matter in the adoption of a robo-advice technology tool.},
    number = {6},

}